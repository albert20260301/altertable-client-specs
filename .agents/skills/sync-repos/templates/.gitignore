# Global .gitignore for Altertable SDKs
# This file is templated. The {language_ignores} placeholder is replaced with
# the language-specific ignores fetched from the official GitHub/Toptal API.

# --- Global / Editor ---
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Spec Submodule ---
# The specs/ directory is a submodule, we ignore its contents but track the folder
specs/*
!specs/.gitkeep

# --- Language Specific ({language}) ---
{language_ignores}
